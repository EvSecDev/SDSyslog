[Unit]
Description=Secure Diode System Logger (SDSyslog) Receiver
Documentation=https://github.com/EvSecDev/SDSyslog
After=network.target

# Safety: Ensure bpf cap when in restricted environments (i.e. containers)
AssertCapability=CAP_BPF
AssertCapability=CAP_SYS_RESOURCE

[Service]
User=root
Group=adm
StandardOutput=journal
StandardError=journal
ExecStart=$executableFilePath receive --config $receiveConfigFilePath
Type=notify-reload
RestartSec=60
Restart=on-abnormal

# Socket draining eBPF program permissions
AmbientCapabilities=CAP_BPF CAP_SYS_RESOURCE
CapabilityBoundingSet=CAP_BPF CAP_SYS_RESOURCE

[Install]
WantedBy=multi-user.target
